# EditorConfig helps maintain consistent encoding, indentation, and line endings
root = true

[*]
charset = utf-8
insert_final_newline = true
end_of_line = lf

[*.js]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.json]
indent_style = space
indent_size = 2

[*.html]
indent_style = space
indent_size = 2

[*.yaml]
indent_style = space
indent_size = 2

[*.css]
indent_style = space
indent_size = 2
